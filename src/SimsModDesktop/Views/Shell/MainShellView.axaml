<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shell="clr-namespace:SimsModDesktop.Presentation.ViewModels.Shell;assembly=SimsModDesktop.Presentation"
             xmlns:shellViews="clr-namespace:SimsModDesktop.Views.Shell"
             xmlns:saves="clr-namespace:SimsModDesktop.Views.Saves"
             xmlns:workspace="clr-namespace:SimsModDesktop.Views.Workspace"
             mc:Ignorable="d"
             x:Class="SimsModDesktop.Views.Shell.MainShellView"
             x:DataType="shell:MainShellViewModel">
    <Grid x:Name="ShellRoot"
          Focusable="True"
          PointerPressed="OnShellPointerPressed">
        <Grid Margin="16" ColumnSpacing="{Binding ShellColumnSpacing}" RowDefinitions="*" MinHeight="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="56" MaxWidth="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Classes="sidebar-shell"
                    Width="{Binding SidebarWidth}"
                    HorizontalAlignment="Left"
                    Padding="0,12,0,12">
                <ScrollViewer Width="{Binding SidebarWidth}"
                              HorizontalAlignment="Left"
                              MinHeight="0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <DockPanel Margin="8,0" MinHeight="40" IsVisible="{Binding IsSidebarExpanded}">
                            <Button DockPanel.Dock="Right"
                                    Classes="secondary"
                                    Padding="0"
                                    CornerRadius="12"
                                    Width="40"
                                    Height="40"
                                    VerticalAlignment="Center"
                                    Command="{Binding ToggleSidebarCommand}">
                                <PathIcon Data="{StaticResource Icon.Menu}" Width="14" Height="14" />
                            </Button>

                            <StackPanel Spacing="4" VerticalAlignment="Center" IsVisible="{Binding ShowSidebarBranding}">
                                <TextBlock Classes="sidebar-kicker" Text="SimsToolkit" />
                                <TextBlock Classes="sidebar-minimal-title" Text="Workspace" />
                            </StackPanel>
                        </DockPanel>

                        <Button IsVisible="{Binding IsSidebarCollapsed}"
                                Classes="secondary"
                                Width="40"
                                Height="40"
                                Padding="0"
                                CornerRadius="12"
                                HorizontalAlignment="Center"
                                Command="{Binding ToggleSidebarCommand}">
                            <PathIcon Data="{StaticResource Icon.Menu}" Width="14" Height="14" />
                        </Button>

                        <Border Margin="8,0"
                                Classes="sidebar-subtle-block"
                                Classes.sidebar-compact-chip="{Binding IsSidebarCollapsed}"
                                Classes.path-health-interactive="{Binding IsPathHealthExpanded}"
                                Padding="8"
                                IsHitTestVisible="{Binding IsPathHealthExpanded}"
                                IsVisible="{Binding ShowCompactPathHealth}"
                                PointerPressed="OnPathHealthPointerPressed">
                            <Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding IsSidebarExpanded}">
                                    <Border Classes="status-dot"
                                            Classes.status-ok="{Binding HasAllCorePathsValid}"
                                            Classes.status-missing="{Binding !HasAllCorePathsValid}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            ToolTip.Tip="Path Health Status" />
                                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Classes="helper-text" Text="Workspace Paths" />
                                        <TextBlock Classes="helper-text" Text="{Binding PathHealthSummary}" />
                                    </StackPanel>
                                </Grid>

                                <Border IsVisible="{Binding IsSidebarCollapsed}"
                                        Classes="status-dot"
                                        Classes.status-ok="{Binding HasAllCorePathsValid}"
                                        Classes.status-missing="{Binding !HasAllCorePathsValid}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="{Binding PathHealthSummary}" />
                            </Grid>
                        </Border>

                        <Border Margin="8,0"
                                Classes="sidebar-subtle-block"
                                Classes.path-health-interactive="{Binding IsPathHealthExpanded}"
                                Padding="8"
                                IsHitTestVisible="{Binding IsPathHealthExpanded}"
                                IsVisible="{Binding ShowDetailedPathHealth}"
                                PointerPressed="OnPathHealthPointerPressed">
                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto,Auto,Auto"
                                  ColumnSpacing="8"
                                  RowSpacing="6">
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Border Classes="status-dot"
                                            Classes.status-ok="{Binding HasGameExecutable}"
                                            Classes.status-warning="{Binding IsGameExecutableWarning}"
                                            Classes.status-missing="{Binding IsGameExecutableMissing}" />
                                    <TextBlock VerticalAlignment="Center" Text="Game" />
                                </StackPanel>
                                <Border Grid.Row="0"
                                        Grid.Column="1"
                                        Classes="status-pill"
                                        Classes.status-ok="{Binding HasGameExecutable}"
                                        Classes.status-warning="{Binding IsGameExecutableWarning}"
                                        Classes.status-missing="{Binding IsGameExecutableMissing}">
                                    <TextBlock Classes="status-pill-text" Text="{Binding GameStatusBadgeText}" />
                                </Border>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Border Classes="status-dot"
                                            Classes.status-ok="{Binding HasModsPath}"
                                            Classes.status-warning="{Binding IsModsPathWarning}"
                                            Classes.status-missing="{Binding IsModsPathMissing}" />
                                    <TextBlock VerticalAlignment="Center" Text="Mods" />
                                </StackPanel>
                                <Border Grid.Row="1"
                                        Grid.Column="1"
                                        Classes="status-pill"
                                        Classes.status-ok="{Binding HasModsPath}"
                                        Classes.status-warning="{Binding IsModsPathWarning}"
                                        Classes.status-missing="{Binding IsModsPathMissing}">
                                    <TextBlock Classes="status-pill-text" Text="{Binding ModsStatusBadgeText}" />
                                </Border>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Border Classes="status-dot"
                                            Classes.status-ok="{Binding HasTrayPath}"
                                            Classes.status-warning="{Binding IsTrayPathWarning}"
                                            Classes.status-missing="{Binding IsTrayPathMissing}" />
                                    <TextBlock VerticalAlignment="Center" Text="Tray" />
                                </StackPanel>
                                <Border Grid.Row="2"
                                        Grid.Column="1"
                                        Classes="status-pill"
                                        Classes.status-ok="{Binding HasTrayPath}"
                                        Classes.status-warning="{Binding IsTrayPathWarning}"
                                        Classes.status-missing="{Binding IsTrayPathMissing}">
                                    <TextBlock Classes="status-pill-text" Text="{Binding TrayStatusBadgeText}" />
                                </Border>

                                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Border Classes="status-dot"
                                            Classes.status-ok="{Binding HasSavesPath}"
                                            Classes.status-warning="{Binding IsSavesPathWarning}"
                                            Classes.status-missing="{Binding IsSavesPathMissing}" />
                                    <TextBlock VerticalAlignment="Center" Text="Saves" />
                                </StackPanel>
                                <Border Grid.Row="3"
                                        Grid.Column="1"
                                        Classes="status-pill"
                                        Classes.status-ok="{Binding HasSavesPath}"
                                        Classes.status-warning="{Binding IsSavesPathWarning}"
                                        Classes.status-missing="{Binding IsSavesPathMissing}">
                                    <TextBlock Classes="status-pill-text" Text="{Binding SavesStatusBadgeText}" />
                                </Border>
                            </Grid>
                        </Border>

                        <StackPanel Spacing="4" Margin="8,0">
                            <Button Classes="sidebar-link-minimal"
                                    Classes.sidebar-active="{Binding IsToolkitSectionSelected}"
                                    Classes.sidebar-link-collapsed="{Binding IsSidebarCollapsed}"
                                    Command="{Binding SelectSectionCommand}"
                                    CommandParameter="Toolkit"
                                    ToolTip.Tip="Toolkit">
                                <Grid>
                                    <Grid ColumnDefinitions="24,*" ColumnSpacing="12" IsVisible="{Binding IsSidebarExpanded}">
                                        <PathIcon Grid.Column="0" Data="{StaticResource Icon.Toolkit}" Width="16" Height="16" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Toolkit" VerticalAlignment="Center" />
                                    </Grid>
                                    <PathIcon IsVisible="{Binding IsSidebarCollapsed}"
                                              Data="{StaticResource Icon.Toolkit}"
                                              Width="16"
                                              Height="16"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <Button Classes="sidebar-link-minimal"
                                    Classes.sidebar-active="{Binding IsModsSectionSelected}"
                                    Classes.sidebar-link-collapsed="{Binding IsSidebarCollapsed}"
                                    Command="{Binding SelectSectionCommand}"
                                    CommandParameter="Mods"
                                    ToolTip.Tip="Mods">
                                <Grid>
                                    <Grid ColumnDefinitions="24,*" ColumnSpacing="12" IsVisible="{Binding IsSidebarExpanded}">
                                        <PathIcon Grid.Column="0" Data="{StaticResource Icon.Mods}" Width="16" Height="16" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Mods" VerticalAlignment="Center" />
                                    </Grid>
                                    <PathIcon IsVisible="{Binding IsSidebarCollapsed}"
                                              Data="{StaticResource Icon.Mods}"
                                              Width="16"
                                              Height="16"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <Button Classes="sidebar-link-minimal"
                                    Classes.sidebar-active="{Binding IsTraySectionSelected}"
                                    Classes.sidebar-link-collapsed="{Binding IsSidebarCollapsed}"
                                    Command="{Binding SelectSectionCommand}"
                                    CommandParameter="Tray"
                                    ToolTip.Tip="Tray">
                                <Grid>
                                    <Grid ColumnDefinitions="24,*" ColumnSpacing="12" IsVisible="{Binding IsSidebarExpanded}">
                                        <PathIcon Grid.Column="0" Data="{StaticResource Icon.Tray}" Width="16" Height="16" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Tray" VerticalAlignment="Center" />
                                    </Grid>
                                    <PathIcon IsVisible="{Binding IsSidebarCollapsed}"
                                              Data="{StaticResource Icon.Tray}"
                                              Width="16"
                                              Height="16"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <Button Classes="sidebar-link-minimal"
                                    Classes.sidebar-active="{Binding IsSavesSectionSelected}"
                                    Classes.sidebar-link-collapsed="{Binding IsSidebarCollapsed}"
                                    Command="{Binding SelectSectionCommand}"
                                    CommandParameter="Saves"
                                    ToolTip.Tip="Saves">
                                <Grid>
                                    <Grid ColumnDefinitions="24,*" ColumnSpacing="12" IsVisible="{Binding IsSidebarExpanded}">
                                        <PathIcon Grid.Column="0" Data="{StaticResource Icon.Saves}" Width="16" Height="16" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Saves" VerticalAlignment="Center" />
                                    </Grid>
                                    <PathIcon IsVisible="{Binding IsSidebarCollapsed}"
                                              Data="{StaticResource Icon.Saves}"
                                              Width="16"
                                              Height="16"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <Button Classes="sidebar-link-minimal"
                                    Classes.sidebar-active="{Binding IsSettingsSectionSelected}"
                                    Classes.sidebar-link-collapsed="{Binding IsSidebarCollapsed}"
                                    Command="{Binding SelectSectionCommand}"
                                    CommandParameter="Settings"
                                    ToolTip.Tip="Settings">
                                <Grid>
                                    <Grid ColumnDefinitions="24,*" ColumnSpacing="12" IsVisible="{Binding IsSidebarExpanded}">
                                        <PathIcon Grid.Column="0" Data="{StaticResource Icon.Settings}" Width="16" Height="16" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Settings" VerticalAlignment="Center" />
                                    </Grid>
                                    <PathIcon IsVisible="{Binding IsSidebarCollapsed}"
                                              Data="{StaticResource Icon.Settings}"
                                              Width="16"
                                              Height="16"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1"
                  MinHeight="0"
                  RowDefinitions="Auto,*"
                  RowSpacing="10">
                <Border Grid.Row="0"
                        Classes="card-muted"
                        Padding="12"
                        IsVisible="{Binding IsTrayDependencyCacheWarmupVisible}">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="settings-section-title" Text="{Binding TrayDependencyCacheWarmupTitle}" />
                        <TextBlock Classes="helper-text"
                                   Text="{Binding TrayDependencyCacheWarmupHint}"
                                   TextWrapping="Wrap" />
                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     Height="10"
                                     IsIndeterminate="{Binding IsTrayDependencyCacheWarmupIndeterminate}"
                                     Value="{Binding TrayDependencyCacheWarmupPercent}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBlock Classes="helper-text"
                                       Text="{Binding TrayDependencyCacheWarmupDetail}"
                                       TextWrapping="Wrap" />
                            <TextBlock Grid.Column="1"
                                       Classes="helper-text"
                                       HorizontalAlignment="Right"
                                       Text="{Binding TrayDependencyCacheWarmupPercentText}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1" MinHeight="0">
                    <Border Classes="card" Padding="24" IsVisible="{Binding IsSavesVisible}">
                        <saves:SavesView DataContext="{Binding SavesVm}" />
                    </Border>

                    <Border Classes="card" Padding="24" IsVisible="{Binding IsSettingsVisible}">
                        <StackPanel Spacing="24">
                        <TextBlock Classes="section-title" Text="Settings" />

                        <Border Classes="settings-section" Padding="20">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="settings-section-title" Text="Game Paths" />
                                    <TextBlock Classes="settings-section-description"
                                               Text="Set The Sims 4 Root. Game, Mods, Tray and Saves paths are derived automatically." />
                                </StackPanel>

                                <Grid Classes="settings-path-grid"
                                      ColumnDefinitions="220,*,Auto"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                      RowSpacing="12"
                                      ColumnSpacing="12">
                                    <TextBlock Classes="settings-field-label" Text="The Sims 4 Root" />
                                    <TextBox x:Name="Ts4RootPathTextBox"
                                             Grid.Column="1"
                                             Classes="path-field"
                                             Text="{Binding Ts4RootPath}" />
                                    <Button Grid.Column="2"
                                            Classes="secondary"
                                            Content="Browse"
                                            Command="{Binding BrowseTs4RootCommand}" />

                                    <TextBlock Grid.Row="1" Classes="settings-field-label" Text="Game Executable" />
                                    <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Classes="settings-readonly-field">
                                        <TextBlock Classes="settings-readonly-value" Text="{Binding GameExecutablePath}" />
                                    </Border>

                                    <TextBlock Grid.Row="2" Classes="settings-field-label" Text="Mods Path" />
                                    <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Classes="settings-readonly-field">
                                        <TextBlock Classes="settings-readonly-value" Text="{Binding ModsPath}" />
                                    </Border>

                                    <TextBlock Grid.Row="3" Classes="settings-field-label" Text="Tray Path" />
                                    <Border Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Classes="settings-readonly-field">
                                        <TextBlock Classes="settings-readonly-value" Text="{Binding TrayPath}" />
                                    </Border>

                                    <TextBlock Grid.Row="4" Classes="settings-field-label" Text="Saves Path" />
                                    <Border Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Classes="settings-readonly-field">
                                        <TextBlock Classes="settings-readonly-value" Text="{Binding SavesPath}" />
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="settings-section" Padding="12">
                            <StackPanel Spacing="10">
                                <StackPanel Spacing="2">
                                    <TextBlock Classes="settings-section-title" Text="Appearance" />
                                    <TextBlock Classes="settings-section-description"
                                               Text="Choose application theme." />
                                </StackPanel>

                                <Grid ColumnDefinitions="220,*" RowDefinitions="Auto" RowSpacing="8" ColumnSpacing="8">
                                    <TextBlock VerticalAlignment="Center" Text="Theme" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <Button Classes="secondary"
                                                Classes.sidebar-active="{Binding IsDarkThemeSelected}"
                                                Content="Dark"
                                                Command="{Binding SetDarkThemeCommand}" />
                                        <Button Classes="secondary"
                                                Classes.sidebar-active="{Binding IsLightThemeSelected}"
                                                Content="Light"
                                                Command="{Binding SetLightThemeCommand}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="settings-section" Padding="12">
                            <StackPanel Spacing="10">
                                <StackPanel Spacing="2">
                                    <TextBlock Classes="settings-section-title" Text="Cache" />
                                    <TextBlock Classes="settings-section-description"
                                               Text="Clear on-disk thumbnail and metadata caches. Restart the app to fully drop in-memory caches." />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Classes="secondary"
                                            Content="Clear Cache"
                                            Command="{Binding ClearCacheCommand}" />
                                    <TextBlock VerticalAlignment="Center"
                                               Classes="helper-text"
                                               Text="{Binding CacheMaintenanceStatus}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Classes="settings-section" Padding="12">
                            <StackPanel Spacing="10">
                                <StackPanel Spacing="2">
                                    <TextBlock Classes="settings-section-title" Text="Debug Config Table" />
                                    <TextBlock Classes="settings-section-description"
                                               Text="Toggle internal behaviors without code changes. These options are saved to debug-config.ini." />
                                </StackPanel>

                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                    <TextBlock Classes="helper-text" Text="Option" />
                                    <TextBlock Grid.Column="1" Classes="helper-text" HorizontalAlignment="Center" Text="Default" />
                                    <TextBlock Grid.Column="2" Classes="helper-text" HorizontalAlignment="Center" Text="Current" />
                                </Grid>

                                <ItemsControl ItemsSource="{Binding DebugConfigItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="shell:DebugConfigToggleItemViewModel">
                                            <Border Classes="card-muted" Padding="8">
                                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                                        <TextBlock Classes="helper-text" Text="{Binding Description}" TextWrapping="Wrap" />
                                                        <TextBlock Classes="helper-text" Text="{Binding Key}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               Text="{Binding DefaultValueText}" />
                                                    <CheckBox Grid.Column="2"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Center"
                                                              IsChecked="{Binding Value}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Classes="secondary"
                                            Content="Reset Debug Config"
                                            Command="{Binding ResetDebugConfigCommand}" />
                                    <TextBlock VerticalAlignment="Center"
                                               Classes="helper-text"
                                               Text="Changes apply immediately where supported and persist on app close." />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                    </Border>

                    <Grid IsVisible="{Binding IsWorkspaceSectionVisible}" MinHeight="0">
                        <workspace:WorkspaceView DataContext="{Binding WorkspaceVm}" MinHeight="0" />
                    </Grid>
                </Grid>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
