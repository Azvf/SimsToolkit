<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SimsModDesktop.Presentation.ViewModels.Saves;assembly=SimsModDesktop.Presentation"
             xmlns:preview="clr-namespace:SimsModDesktop.Views.Preview"
             xmlns:savedata="clr-namespace:SimsModDesktop.SaveData.Models;assembly=SimsModDesktop.SaveData"
             mc:Ignorable="d"
             x:Class="SimsModDesktop.Views.Saves.SavesView"
             x:DataType="vm:SaveWorkspaceViewModel">
    <Grid RowDefinitions="Auto,*"
          RowSpacing="24"
          MinHeight="0">
        <Border Classes="card-muted"
                Padding="16">
            <Grid RowDefinitions="Auto,Auto"
                  RowSpacing="16">
                <Grid ColumnDefinitions="Auto,260,Auto,Auto,Auto,*,Auto,Auto"
                      ColumnSpacing="12">
                    <TextBlock VerticalAlignment="Center" Text="Current Save" />
                    <ComboBox Grid.Column="1"
                              SelectedItem="{Binding SelectedSave}"
                              ItemsSource="{Binding SaveFiles}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="savedata:SaveFileEntry">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding FileName}" />
                                    <TextBlock Classes="helper-text"
                                               Text="{Binding DisplayLabel}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="2"
                            Classes="secondary"
                            Content="Refresh Saves"
                            Command="{Binding RefreshSavesCommand}" />
                    <Button Grid.Column="3"
                            Classes="secondary"
                            Content="Rebuild Cache"
                            Command="{Binding RebuildCacheCommand}" />
                    <Button Grid.Column="4"
                            Classes="secondary"
                            Content="Clear Cache"
                            Command="{Binding ClearSelectedSaveCacheCommand}" />

                    <TextBlock Grid.Column="5"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Text="Export Root" />
                    <TextBox Grid.Column="6"
                             Classes="path-field"
                             Text="{Binding ExportRootPath}" />
                    <Button Grid.Column="7"
                            Classes="secondary"
                            Content="Browse"
                            Command="{Binding BrowseExportRootCommand}" />
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="1.1*,1.4*"
                      ColumnSpacing="16">
                    <StackPanel Spacing="8">
                        <CheckBox Content="Generate Thumbnails"
                                  IsChecked="{Binding GenerateThumbnails}" />
                        <TextBlock Text="{Binding SelectedSaveSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="helper-text"
                                   Text="{Binding CacheStatusText}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="helper-text"
                                   Text="{Binding StatusText}"
                                   TextWrapping="Wrap" />
                        <ProgressBar Minimum="0"
                                     Maximum="1"
                                     IsIndeterminate="{Binding IsBuildingCache}" />
                    </StackPanel>

                    <preview:TrayLikePreviewFilterBarView Grid.Column="1"
                                                          DataContext="{Binding Filter}" />
                </Grid>
            </Grid>
        </Border>

        <preview:TrayLikePreviewSurfaceView Grid.Row="1"
                                            DataContext="{Binding Surface}" />
    </Grid>
</UserControl>

