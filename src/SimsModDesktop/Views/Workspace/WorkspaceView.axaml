<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:SimsModDesktop.Models"
             xmlns:panels="clr-namespace:SimsModDesktop.Views.Panels"
             xmlns:preview="clr-namespace:SimsModDesktop.Views.Preview"
             xmlns:panelvm="clr-namespace:SimsModDesktop.Presentation.ViewModels.Panels;assembly=SimsModDesktop.Presentation"
             xmlns:vm="clr-namespace:SimsModDesktop.Presentation.ViewModels;assembly=SimsModDesktop.Presentation"
             mc:Ignorable="d"
             x:Class="SimsModDesktop.Views.Workspace.WorkspaceView"
             x:DataType="vm:MainWindowViewModel">
    <Grid RowDefinitions="*,Auto" RowSpacing="12" MinHeight="0">
        <Grid>
            <Border Classes="card" IsVisible="{Binding IsToolkitWorkspace}" Padding="24">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="24">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="section-title" Text="Toolkit Workspace" />
                        <TextBlock Classes="helper-text"
                                   Text="Utility-focused workflows for common Mods folder cleanup, organization, and dependency tasks." />
                    </StackPanel>

                    <Border Grid.Row="1" Classes="card-muted" Padding="16">
                        <Grid ColumnDefinitions="Auto,200,*" ColumnSpacing="12">
                            <TextBlock VerticalAlignment="Center" Text="Action" />
                            <ComboBox Grid.Column="1" Width="180" ItemsSource="{Binding AvailableToolkitActions}" SelectedItem="{Binding SelectedAction}" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Classes="helper-text" Text="Select an action, adjust parameters, then run." />
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="2">
                        <StackPanel Spacing="16">
                            <panels:OrganizePanelView />
                            <panels:FlattenPanelView />
                            <panels:NormalizePanelView />
                            <panels:MergePanelView />
                            <panels:FindDupPanelView />
                            <panels:TrayDependenciesPanelView />
                            <Border Classes="card-muted"
                                    Padding="16"
                                    IsVisible="{Binding IsSharedFileOpsVisible}">
                                <Grid ColumnDefinitions="240,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto"
                                      RowSpacing="12"
                                      ColumnSpacing="12">
                                    <TextBlock Grid.ColumnSpan="2"
                                               Classes="sub-title"
                                               Text="Shared File Operation Options for Flatten, Merge, and FindDuplicates" />

                                    <CheckBox Grid.Row="1"
                                              Grid.Column="1"
                                              Content="Skip empty directory cleanup"
                                              IsChecked="{Binding SharedFileOps.SkipPruneEmptyDirs}" />
                                    <CheckBox Grid.Row="2"
                                              Grid.Column="1"
                                              Content="Process mod files only"
                                              IsChecked="{Binding SharedFileOps.ModFilesOnly}" />
                                    <CheckBox Grid.Row="3"
                                              Grid.Column="1"
                                              Content="Verify content on name conflicts"
                                              IsChecked="{Binding SharedFileOps.VerifyContentOnNameConflict}" />
                                </Grid>
                            </Border>

                            <Border Classes="card-muted"
                                    Padding="16"
                                    IsVisible="{Binding IsSharedFileOpsVisible}">
                                <Grid ColumnDefinitions="240,*" ColumnSpacing="12">
                                    <TextBlock VerticalAlignment="Center" Text="Extensions" />
                                    <TextBox Grid.Column="1" Text="{Binding SharedFileOps.ModExtensionsText}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Classes="card" IsVisible="{Binding IsModPreviewWorkspace}" Padding="24" MinHeight="0">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="24" MinHeight="0">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="section-title" Text="Mod Workspace" />
                        <TextBlock Classes="helper-text"
                                   Text="Browse indexed CAS and Build/Buy items like an in-game catalog." />
                    </StackPanel>

                    <Border Grid.Row="1" Classes="card-muted" Padding="16">
                        <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="12">
                            <TextBlock VerticalAlignment="Center" Text="Item Type" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ModPreviewPackageTypeFilterOptions}"
                                      SelectedItem="{Binding ModPreview.PackageTypeFilter}" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Subtype" />
                            <ComboBox Grid.Column="3"
                                      ItemsSource="{Binding ModPreviewScopeFilterOptions}"
                                      SelectedItem="{Binding ModPreview.ScopeFilter}" />
                            <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="Sort" />
                            <ComboBox Grid.Column="5"
                                      ItemsSource="{Binding ModPreviewSortOptions}"
                                      SelectedItem="{Binding ModPreview.SortBy}" />

                            <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Search" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Grid.ColumnSpan="3"
                                     Watermark="Item name or source package"
                                     Text="{Binding ModPreview.SearchQuery}" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="4"
                                       Grid.ColumnSpan="2"
                                       Classes="helper-text"
                                       VerticalAlignment="Center"
                                       Text="{Binding ModPreviewWorkspace.IndexingStatusText}"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Classes="card-muted" Padding="16" MinHeight="0">
                        <Grid RowDefinitions="Auto,*" RowSpacing="16" MinHeight="0">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                <TextBlock Classes="helper-text"
                                           VerticalAlignment="Center"
                                           Text="{Binding ModPreviewPathHintText}" />
                                <TextBlock Grid.Column="1"
                                           Classes="helper-text"
                                           VerticalAlignment="Center"
                                           Text="{Binding ModPreviewWorkspace.SummaryText}" />
                                <Button Grid.Column="2"
                                        Classes="secondary"
                                        Content="Refresh"
                                        Command="{Binding ModPreviewWorkspace.RefreshCommand}" />
                            </Grid>

                            <Grid Grid.Row="1"
                                  ColumnDefinitions="*,420"
                                  ColumnSpacing="16"
                                  MinHeight="0">
                                <Border Classes="card"
                                        Padding="16"
                                        MinHeight="0">
                                    <Grid RowDefinitions="Auto,*"
                                          RowSpacing="16"
                                          MinHeight="0">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="sub-title" Text="Item Catalog" />
                                            <TextBlock Classes="helper-text"
                                                       Text="{Binding ModPreviewWorkspace.StatusText}" />
                                        </StackPanel>

                                        <preview:ModPreviewCatalogSurfaceView Grid.Row="1"
                                                                              DataContext="{Binding ModPreviewWorkspace}" />
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1"
                                        Classes="card"
                                        Padding="16"
                                        MaxWidth="420"
                                        MinHeight="0">
                                    <Grid RowDefinitions="Auto,*"
                                          RowSpacing="16"
                                          MinHeight="0">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="sub-title" Text="Item Inspect" />
                                            <TextBlock Classes="helper-text"
                                                       Text="A compact inspect pane that updates with the selected catalog item." />
                                        </StackPanel>

                                        <preview:ModPreviewDetailSurfaceView Grid.Row="1"
                                                                             DataContext="{Binding ModPreviewWorkspace.Inspect}" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Classes="card" IsVisible="{Binding IsTrayPreviewWorkspace}" Padding="24" MinHeight="0">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="24"
                      MinHeight="0">
                    <Border Classes="card-muted" Padding="16">
                        <preview:TrayLikePreviewFilterBarView DataContext="{Binding TrayPreviewWorkspace.Filter}" />
                    </Border>

                    <preview:TrayLikePreviewSurfaceView Grid.Row="1"
                                                        DataContext="{Binding TrayPreviewWorkspace.Surface}" />
                </Grid>
            </Border>

        </Grid>

        <Border x:Name="TrayPreviewDetailOverlay"
                IsVisible="{Binding IsTrayPreviewDetailVisible}"
                Grid.Row="0"
                Focusable="True"
                Background="#B00A1220"
                CornerRadius="16"
                Padding="18">
            <Border Classes="card"
                    Padding="16"
                    MinHeight="0">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="12"
                      MinHeight="0">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="12">
                        <Button Classes="secondary"
                                Content="Back"
                                IsVisible="{Binding CanGoBackTrayPreviewDetail}"
                                Command="{Binding GoBackTrayPreviewDetailCommand}" />
                        <StackPanel Grid.Column="1"
                                    Spacing="2">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <TextBlock Classes="helper-text"
                                           Text="{Binding TrayPreviewDetailItem.Item.PresetType}" />
                                <TextBlock Classes="helper-text"
                                           Text="{Binding TrayPreviewDetailItem.Item.DisplayPrimaryMeta}"
                                           IsVisible="{Binding TrayPreviewDetailItem.Item.HasDisplayPrimaryMeta}" />
                            </StackPanel>
                            <TextBlock Classes="section-title"
                                       Text="{Binding TrayPreviewDetailItem.Item.DisplayTitle}" />
                            <TextBlock Classes="helper-text"
                                       IsVisible="{Binding TrayPreviewDetailItem.Item.HasDisplaySubtitle}"
                                       Text="{Binding TrayPreviewDetailItem.Item.DisplaySubtitle}" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Classes="secondary"
                                Content="Close"
                                Command="{Binding CloseTrayPreviewDetailCommand}" />
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  MinHeight="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="14">
                            <Grid ColumnDefinitions="320,*"
                                  ColumnSpacing="16">
                                <Border Width="320"
                                        Height="240"
                                        VerticalAlignment="Top"
                                        CornerRadius="12"
                                        ClipToBounds="True"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        Background="{DynamicResource Brush.Surface}">
                                    <Grid>
                                        <Image IsVisible="{Binding TrayPreviewDetailItem.HasThumbnail}"
                                               Stretch="Uniform"
                                               Source="{Binding TrayPreviewDetailItem.Thumbnail}" />
                                        <Border Width="110"
                                                Height="8"
                                                IsVisible="{Binding TrayPreviewDetailItem.IsThumbnailLoading}"
                                                Background="{DynamicResource Brush.Panel}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <Border Width="34"
                                                    Height="8"
                                                    Background="{DynamicResource Brush.Primary}"
                                                    CornerRadius="999"
                                                    HorizontalAlignment="Left" />
                                        </Border>
                                        <TextBlock IsVisible="{Binding TrayPreviewDetailItem.IsThumbnailPlaceholderVisible}"
                                                   Text="No Preview"
                                                   Classes="helper-text"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Spacing="8">
                                    <TextBlock FontWeight="SemiBold"
                                               IsVisible="{Binding TrayPreviewDetailItem.Item.HasDisplaySecondaryMeta}"
                                               Text="{Binding TrayPreviewDetailItem.Item.DisplaySecondaryMeta}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Classes="helper-text"
                                               IsVisible="{Binding TrayPreviewDetailItem.Item.HasDisplayTertiaryMeta}"
                                               Text="{Binding TrayPreviewDetailItem.Item.DisplayTertiaryMeta}" />
                                    <Border Classes="card-muted"
                                            Padding="12">
                                        <StackPanel Spacing="6">
                                            <TextBlock Classes="sub-title"
                                                       Text="Background" />
                                            <TextBlock IsVisible="{Binding TrayPreviewDetailItem.Item.HasDisplayDescription}"
                                                       Text="{Binding TrayPreviewDetailItem.Item.DisplayDescription}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Classes="helper-text"
                                                       IsVisible="{Binding IsTrayPreviewDetailDescriptionEmpty}"
                                                       Text="No in-game description was found for this tray item." />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <preview:TrayItemDetailSurfaceView DataContext="{Binding TrayPreviewDetailItem.Item}" />

                            <Border Classes="card-muted"
                                    Padding="12"
                                    IsVisible="{Binding CanGoBackTrayPreviewDetail}">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="sub-title"
                                               Text="Navigation" />
                                    <TextBlock Classes="helper-text"
                                               Text="You are viewing a nested member detail. Use Back to return to the previous household or sim page." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Border>

        <Border Grid.RowSpan="2"
                Classes="card tray-export-queue"
                IsVisible="{Binding IsTrayExportQueueVisible}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Width="360"
                MaxWidth="360"
                Margin="0,0,12,56"
                Padding="10">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                    <StackPanel Spacing="2">
                        <TextBlock Classes="sub-title"
                                   Text="Export Queue" />
                        <TextBlock Classes="helper-text"
                                   Text="{Binding TrayExportQueueSummaryText}" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="secondary"
                            Height="28"
                            Padding="10,0"
                            IsVisible="{Binding HasCompletedTrayExportTasks}"
                            Content="Clear Finished"
                            Command="{Binding ClearCompletedTrayExportTasksCommand}" />
                </Grid>

                <ScrollViewer Grid.Row="1"
                              MaxHeight="240"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding TrayExportTasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TrayExportTaskItemViewModel">
                                <Border Classes="card-muted tray-export-task-card"
                                        Classes.running="{Binding IsRunning}"
                                        Classes.failed="{Binding IsFailed}"
                                        Cursor="Hand"
                                        Margin="0,0,0,8"
                                        Padding="10"
                                        PointerPressed="OnTrayExportTaskPointerPressed">
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                          RowSpacing="4">
                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                              ColumnSpacing="8">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding Title}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Classes="helper-text"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding ProgressText}" />
                                            <Button Grid.Column="2"
                                                    Classes="secondary"
                                                    Height="26"
                                                    Padding="8,0"
                                                    Focusable="False"
                                                    IsVisible="{Binding CanShowDetailsToggle}"
                                                    Content="Details"
                                                    Click="OnTrayExportTaskDetailsClick" />
                                        </Grid>

                                        <ProgressBar Grid.Row="1"
                                                     Height="6"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding ProgressPercent}" />

                                        <TextBlock Grid.Row="2"
                                                   Classes="helper-text"
                                                   Text="{Binding StatusText}"
                                                   TextWrapping="Wrap" />

                                        <Border Grid.Row="3"
                                                Classes="card-muted"
                                                IsVisible="{Binding IsDetailsExpanded}"
                                                Padding="8"
                                                Margin="0,4,0,0">
                                            <ScrollViewer MaxHeight="120"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <TextBlock Classes="helper-text"
                                                           Text="{Binding DetailsText}"
                                                           TextWrapping="Wrap" />
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.RowSpan="2"
                Classes="card tray-export-queue-dock"
                IsVisible="{Binding IsTrayExportQueueDockVisible}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                MinWidth="220"
                Margin="0,0,12,12"
                Padding="8">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="8">
                <Button Classes="secondary"
                        MinWidth="108"
                        Height="30"
                        Padding="10,0"
                        Content="{Binding TrayExportQueueToggleText}"
                        Command="{Binding ToggleTrayExportQueueCommand}" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Classes="helper-text"
                           Text="{Binding TrayExportQueueSummaryText}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="card" Padding="12" IsVisible="{Binding IsToolkitWorkspace}">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="10">
                    <Button Classes="primary" MinWidth="150" Content="Run" Command="{Binding RunActiveWorkspaceCommand}" />
                    <Button Grid.Column="1" Classes="danger" Content="Cancel" Command="{Binding CancelCommand}" />
                    <CheckBox Grid.Column="2" VerticalAlignment="Center" Content="WhatIf" IsChecked="{Binding WhatIf}" />
                </Grid>

                <Grid Grid.Row="1">
                    <ProgressBar Height="10"
                                 Minimum="0"
                                 Maximum="100"
                                 IsIndeterminate="{Binding IsProgressIndeterminate}"
                                 Value="{Binding ProgressValue}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

