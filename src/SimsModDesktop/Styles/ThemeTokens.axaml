<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <ResourceDictionary>
            <x:Double x:Key="Size.ControlHeight">36</x:Double>
            <CornerRadius x:Key="Radius.Small">8</CornerRadius>
            <CornerRadius x:Key="Radius.Medium">12</CornerRadius>
            <CornerRadius x:Key="Radius.Large">16</CornerRadius>
            <Thickness x:Key="Thickness.CardPadding">16</Thickness>
            <Thickness x:Key="Thickness.SectionPadding">12</Thickness>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <!-- Sims 4 Light: Clean white, soft blues, and vibrant UI blue -->
                    <Color x:Key="Color.AppBackground">#F4F8FB</Color>
                    <Color x:Key="Color.Surface">#FFFFFF</Color>
                    <Color x:Key="Color.SurfaceMuted">#EBF3F9</Color>
                    <Color x:Key="Color.SurfaceHover">#F0F6FB</Color>
                    <Color x:Key="Color.SurfacePressed">#DEEBF5</Color>
                    <Color x:Key="Color.Border">#DCE7F0</Color>
                    <Color x:Key="Color.BorderHover">#B8CFE2</Color>
                    <Color x:Key="Color.BorderFocus">#1296DB</Color>
                    <Color x:Key="Color.TextPrimary">#1A2B42</Color>
                    <Color x:Key="Color.TextSecondary">#5C708A</Color>
                    <Color x:Key="Color.Accent">#1296DB</Color>
                    <Color x:Key="Color.AccentHover">#0F85C4</Color>
                    <Color x:Key="Color.AccentPressed">#0C74AB</Color>
                    <Color x:Key="Color.AccentMuted">#E6F4FB</Color>
                    <Color x:Key="Color.AccentMutedHover">#D9EEF9</Color>
                    <Color x:Key="Color.AccentMutedPressed">#CCE8F7</Color>
                    <Color x:Key="Color.Danger">#E04F5F</Color>
                    <Color x:Key="Color.DangerHover">#CC4252</Color>
                    <Color x:Key="Color.DangerPressed">#B83645</Color>
                    <Color x:Key="Color.Warning">#F0A500</Color>
                    <Color x:Key="Color.Success">#4CB050</Color>
                    <Color x:Key="Color.LogBackground">#FAFCFE</Color>
                    <Color x:Key="Color.ListItemHover">#F0F6FB</Color>
                    <Color x:Key="Color.ListItemPressed">#DEEBF5</Color>
                    <Color x:Key="Color.ListItemSelected">#E6F4FB</Color>

                    <SolidColorBrush x:Key="Brush.AppBackground" Color="{DynamicResource Color.AppBackground}" />
                    <SolidColorBrush x:Key="Brush.Surface" Color="{DynamicResource Color.Surface}" />
                    <SolidColorBrush x:Key="Brush.SurfaceMuted" Color="{DynamicResource Color.SurfaceMuted}" />
                    <SolidColorBrush x:Key="Brush.SurfaceHover" Color="{DynamicResource Color.SurfaceHover}" />
                    <SolidColorBrush x:Key="Brush.SurfacePressed" Color="{DynamicResource Color.SurfacePressed}" />
                    <SolidColorBrush x:Key="Brush.Border" Color="{DynamicResource Color.Border}" />
                    <SolidColorBrush x:Key="Brush.BorderHover" Color="{DynamicResource Color.BorderHover}" />
                    <SolidColorBrush x:Key="Brush.BorderFocus" Color="{DynamicResource Color.BorderFocus}" />
                    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{DynamicResource Color.TextPrimary}" />
                    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{DynamicResource Color.TextSecondary}" />
                    <SolidColorBrush x:Key="Brush.Accent" Color="{DynamicResource Color.Accent}" />
                    <SolidColorBrush x:Key="Brush.AccentHover" Color="{DynamicResource Color.AccentHover}" />
                    <SolidColorBrush x:Key="Brush.AccentPressed" Color="{DynamicResource Color.AccentPressed}" />
                    <SolidColorBrush x:Key="Brush.AccentMuted" Color="{DynamicResource Color.AccentMuted}" />
                    <SolidColorBrush x:Key="Brush.AccentMutedHover" Color="{DynamicResource Color.AccentMutedHover}" />
                    <SolidColorBrush x:Key="Brush.AccentMutedPressed" Color="{DynamicResource Color.AccentMutedPressed}" />
                    <SolidColorBrush x:Key="Brush.Danger" Color="{DynamicResource Color.Danger}" />
                    <SolidColorBrush x:Key="Brush.DangerHover" Color="{DynamicResource Color.DangerHover}" />
                    <SolidColorBrush x:Key="Brush.DangerPressed" Color="{DynamicResource Color.DangerPressed}" />
                    <SolidColorBrush x:Key="Brush.Warning" Color="{DynamicResource Color.Warning}" />
                    <SolidColorBrush x:Key="Brush.Success" Color="{DynamicResource Color.Success}" />
                    <SolidColorBrush x:Key="Brush.LogBackground" Color="{DynamicResource Color.LogBackground}" />
                    <SolidColorBrush x:Key="Brush.ListItemHover" Color="{DynamicResource Color.ListItemHover}" />
                    <SolidColorBrush x:Key="Brush.ListItemPressed" Color="{DynamicResource Color.ListItemPressed}" />
                    <SolidColorBrush x:Key="Brush.ListItemSelected" Color="{DynamicResource Color.ListItemSelected}" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <!-- Sims 4 Dark: Deep navy blues inspired by the main menu/loading screen -->
                    <Color x:Key="Color.AppBackground">#102339</Color>
                    <Color x:Key="Color.Surface">#1A304C</Color>
                    <Color x:Key="Color.SurfaceMuted">#223D5E</Color>
                    <Color x:Key="Color.SurfaceHover">#244566</Color>
                    <Color x:Key="Color.SurfacePressed">#2D5278</Color>
                    <Color x:Key="Color.Border">#2F4B70</Color>
                    <Color x:Key="Color.BorderHover">#4A6B96</Color>
                    <Color x:Key="Color.BorderFocus">#33B5E5</Color>
                    <Color x:Key="Color.TextPrimary">#EAF4FC</Color>
                    <Color x:Key="Color.TextSecondary">#9ABBD6</Color>
                    <Color x:Key="Color.Accent">#33B5E5</Color>
                    <Color x:Key="Color.AccentHover">#66C9EF</Color>
                    <Color x:Key="Color.AccentPressed">#0099CC</Color>
                    <Color x:Key="Color.AccentMuted">#1F3A5C</Color>
                    <Color x:Key="Color.AccentMutedHover">#26456B</Color>
                    <Color x:Key="Color.AccentMutedPressed">#2E507A</Color>
                    <Color x:Key="Color.Danger">#FF6B6B</Color>
                    <Color x:Key="Color.DangerHover">#FF8585</Color>
                    <Color x:Key="Color.DangerPressed">#E65252</Color>
                    <Color x:Key="Color.Warning">#FFC107</Color>
                    <Color x:Key="Color.Success">#56C98A</Color>
                    <Color x:Key="Color.LogBackground">#0C1A2B</Color>
                    <Color x:Key="Color.ListItemHover">#244566</Color>
                    <Color x:Key="Color.ListItemPressed">#2D5278</Color>
                    <Color x:Key="Color.ListItemSelected">#1F3A5C</Color>

                    <SolidColorBrush x:Key="Brush.AppBackground" Color="{DynamicResource Color.AppBackground}" />
                    <SolidColorBrush x:Key="Brush.Surface" Color="{DynamicResource Color.Surface}" />
                    <SolidColorBrush x:Key="Brush.SurfaceMuted" Color="{DynamicResource Color.SurfaceMuted}" />
                    <SolidColorBrush x:Key="Brush.SurfaceHover" Color="{DynamicResource Color.SurfaceHover}" />
                    <SolidColorBrush x:Key="Brush.SurfacePressed" Color="{DynamicResource Color.SurfacePressed}" />
                    <SolidColorBrush x:Key="Brush.Border" Color="{DynamicResource Color.Border}" />
                    <SolidColorBrush x:Key="Brush.BorderHover" Color="{DynamicResource Color.BorderHover}" />
                    <SolidColorBrush x:Key="Brush.BorderFocus" Color="{DynamicResource Color.BorderFocus}" />
                    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{DynamicResource Color.TextPrimary}" />
                    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{DynamicResource Color.TextSecondary}" />
                    <SolidColorBrush x:Key="Brush.Accent" Color="{DynamicResource Color.Accent}" />
                    <SolidColorBrush x:Key="Brush.AccentHover" Color="{DynamicResource Color.AccentHover}" />
                    <SolidColorBrush x:Key="Brush.AccentPressed" Color="{DynamicResource Color.AccentPressed}" />
                    <SolidColorBrush x:Key="Brush.AccentMuted" Color="{DynamicResource Color.AccentMuted}" />
                    <SolidColorBrush x:Key="Brush.AccentMutedHover" Color="{DynamicResource Color.AccentMutedHover}" />
                    <SolidColorBrush x:Key="Brush.AccentMutedPressed" Color="{DynamicResource Color.AccentMutedPressed}" />
                    <SolidColorBrush x:Key="Brush.Danger" Color="{DynamicResource Color.Danger}" />
                    <SolidColorBrush x:Key="Brush.DangerHover" Color="{DynamicResource Color.DangerHover}" />
                    <SolidColorBrush x:Key="Brush.DangerPressed" Color="{DynamicResource Color.DangerPressed}" />
                    <SolidColorBrush x:Key="Brush.Warning" Color="{DynamicResource Color.Warning}" />
                    <SolidColorBrush x:Key="Brush.Success" Color="{DynamicResource Color.Success}" />
                    <SolidColorBrush x:Key="Brush.LogBackground" Color="{DynamicResource Color.LogBackground}" />
                    <SolidColorBrush x:Key="Brush.ListItemHover" Color="{DynamicResource Color.ListItemHover}" />
                    <SolidColorBrush x:Key="Brush.ListItemPressed" Color="{DynamicResource Color.ListItemPressed}" />
                    <SolidColorBrush x:Key="Brush.ListItemSelected" Color="{DynamicResource Color.ListItemSelected}" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Styles.Resources>
</Styles>

